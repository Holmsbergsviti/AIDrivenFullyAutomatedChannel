# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_name_or_id
TELEGRAM_BOT_USERNAME=your_bot_username

# OpenAI Configuration (for text generation)
OPENAI_API_KEY=your_openai_api_key

# Channel Configuration
CHANNEL_TOPIC=Signals of the Future
CHANNEL_DESCRIPTION=Short notes about changes already happening — quietly. AI, behavior, money, internet culture, everyday life.\n\nNotice first.\nUnderstand later.\n\nThis is an AI-driven channel.

# Posting Schedule
MORNING_POST_TIME=10:00
EVENING_POST_TIME=20:00
TIMEZONE=UTC

# Image Generation (using DALL-E or Unsplash)
USE_DALLE=false
USE_UNSPLASH=true
UNSPLASH_ACCESS_KEY=your_unsplash_key_if_using

# Free AI Services (alternatives)
USE_GROQ=false
GROQ_API_KEY=your_groq_key_if_using
